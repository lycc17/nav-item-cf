{
  "name": "nav-item",
  "main": "src/index.js",
  "compatibility_date": "2024-03-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nav_db",
      "database_id": "YOUR_D1_DATABASE_ID"
    }
  ],
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS"
  }
}
